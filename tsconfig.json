{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@stonegy/helper/*": ["./packages/helper/src/*"],
      "@stonegy/game-data/*": ["./packages/game-data/src/*"],
      "@stonegy/ui/*": ["./packages/ui/src/*"]
    }
  },
  "include": [
    "packages/*/src",
    "apps/extension",
    "apps/server/src",
    "apps/server/client",
    "apps/server/vite.config.ts",
    "vitest.config.ts"
  ]
}
