{
  "name": "stonegy-helper",
  "private": true,
  "version": "1.2.1",
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter @stonegy/extension dev",
    "build": "bun run --filter @stonegy/extension build",
    "build:chrome": "bun run --filter @stonegy/extension build:chrome",
    "build:firefox": "bun run --filter @stonegy/extension build:firefox",
    "build:safari": "bun run --filter @stonegy/extension build:safari",
    "build:server": "bun run --filter @stonegy/server build",
    "server": "bun run --elide-lines=0 --filter @stonegy/server dev",
    "server:prod": "bun run build:server && NODE_ENV=production bun run --filter @stonegy/server start",
    "set-version": "bun scripts/set-version.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate:game-data": "bun scripts/generate-game-data.mjs",
    "preview": "bun run --filter @stonegy/extension preview"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.2.4"
  }
}
